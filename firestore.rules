rules_version = '2';

// GrowDaily — Firestore security rules
//
// Data model (all confirmed against the actual app code):
//   /users/{uid}                          — profile, XP, gold, streaks,
//                                            unlockedAchievements,
//                                            categoryCompletions, premiumActive
//   /users/{uid}/daily/{dateKey}           — daily habit completions, grid
//                                            activity, intentions, night
//                                            review mood + reflection text
//   /users/{uid}/custom_habits/{habitId}   — user-created habit templates
//   /users/{uid}/focus_plans/{dateKey}     — focus timer sessions
//   /users/{uid}/matrix_tasks/{taskId}     — Eisenhower matrix tasks
//   /users/{uid}/weekly_challenges/{weekKey}
//
// Every document under /users/{uid} belongs to exactly one account and is
// never shared, so the rule is simple: you can only read/write your own
// tree, and nothing else exists in the database.
//
// One deliberate exception: a client is NOT allowed to flip its own
// `premiumActive` field to true. `PremiumNotifier.activate()` currently
// writes this field directly from the client — that's fine during
// development, but once real purchases are wired, entitlement must be
// granted by a trusted backend (a Cloud Function verifying the App
// Store/Play/RevenueCat webhook, using the Admin SDK, which bypasses these
// rules entirely). Until that Cloud Function exists, this rule stops any
// user from just editing the field client-side to unlock Premium for free.
// Deactivating (setting it to false) is left client-writable since that
// direction can't be used to steal anything.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function premiumFieldOk() {
      let before = resource.data.premiumActive;
      let after = request.resource.data.premiumActive;
      return !('premiumActive' in request.resource.data)
          || after == before
          || after == false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && !('premiumActive' in request.resource.data);
      allow update: if isOwner(uid) && premiumFieldOk();
      // Account deletion (AuthNotifier.deleteAccount) deletes this doc
      // directly from the client after re-authenticating, so the owner
      // needs delete access here too.
      allow delete: if isOwner(uid);

      match /{subcollection}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
