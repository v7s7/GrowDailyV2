rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users collection ──────────────────────────────────────────────────────
    match /users/{userId} {

      // Only the authenticated owner can read or write their own document.
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && validUserDocument(request.resource.data);

      // Sub-collections inherit the same owner-only rule.
      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ─── Validation helpers ─────────────────────────────────────────────────────

// Allowed top-level field names on a user document.
// Reject writes that introduce unknown fields to prevent data injection.
function validUserDocument(data) {
  let allowed = [
    'name', 'email', 'plan',
    'streak', 'bestStreak', 'lastStreakDate',
    'availablePoints', 'totalPoints', 'dailyPointsEarned', 'dailySubmissions',
    'completedTasks', 'taskRepeats',
    'quranPoints', 'gymPoints', 'studyPoints', 'waterPoints',
    'sleepPoints', 'phonePoints', 'showerPoints',
    'sabah_athkarPoints', 'masaa_athkarPoints',
    'sabah_athkar', 'masaa_athkar',
    'hydration',
    'unlockedAchievements',
    'earlyCompletions', 'lateCompletions', 'streakRebuilds',
    'notificationPreferences', 'settings'
  ];
  return data.keys().hasOnly(allowed);
}
